<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface_dark"
    android:padding="20dp"
    android:fitsSystemWindows="true">

    <TextView
        android:id="@+id/tvAppsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="التطبيقات"
        android:textColor="@color/text_primary"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tvAppsSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="اختر التطبيقات"
        android:textColor="@color/text_muted"
        android:textSize="14sp"
        android:layout_marginBottom="12dp" />

    <ProgressBar
        android:id="@+id/progressLoading"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:indeterminate="true"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_marginBottom="12dp"
        android:indeterminateTint="@color/teal_500" />

    <LinearLayout
        android:id="@+id/llContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <Switch
                android:id="@+id/switchAllApps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="@color/teal_500"
                android:trackTint="@color/surface_card" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="تحديد الكل"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvApps"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="16dp" />
    </LinearLayout>

    <Button
        android:id="@+id/btnSaveApps"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="حفظ"
        android:textAllCaps="false"
        android:background="@drawable/btn_emerald"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:textStyle="bold" />

</LinearLayout>
