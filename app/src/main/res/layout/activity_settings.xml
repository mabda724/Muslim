<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_dark"
    android:fitsSystemWindows="true">

    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="-100dp"
        android:background="@drawable/glow_emerald"
        android:alpha="0.5" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="48dp"
            android:paddingBottom="32dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <Button
                    android:id="@+id/btnBackSettings"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="←"
                    android:background="@drawable/circle_glass"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="الإعدادات"
                    android:textColor="@color/text_primary"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Theme Selection Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_glass"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="اختر السمة"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <RadioGroup
                    android:id="@+id/radioGroupThemes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/radioDefault"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="8dp" />

                    <RadioButton
                        android:id="@+id/radioLight"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="8dp" />

                    <RadioButton
                        android:id="@+id/radioGreen"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="8dp" />

                    <RadioButton
                        android:id="@+id/radioBlue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="8dp" />

                    <RadioButton
                        android:id="@+id/radioBrown"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="8dp" />

                    <RadioButton
                        android:id="@+id/radioPurple"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary" />
                </RadioGroup>

                <Button
                    android:id="@+id/btnApplyTheme"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="تطبيق السمة"
                    android:textAllCaps="false"
                    android:background="@drawable/btn_primary"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp" />
            </LinearLayout>

            <!-- Achievements Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_glass"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="الإنجازات"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btnViewAchievements"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="عرض جميع الإنجازات"
                    android:textAllCaps="false"
                    android:background="@drawable/btn_secondary"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Smart Reminders Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_glass"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="التذكيرات الذكية"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <Switch
                    android:id="@+id/switchSmartReminders"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="تفعيل التذكيرات الذكية"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/btnSmartInsights"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="عرض رؤى ذكية"
                    android:textAllCaps="false"
                    android:background="@drawable/btn_secondary"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Additional Settings Info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_glass"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="معلومات"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="يمكنك تغيير مظهر التطبيق من خلال اختيار إحدى السمات المتاحة. سيتم تطبيق التغيير فوراً."
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.4" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</FrameLayout>
