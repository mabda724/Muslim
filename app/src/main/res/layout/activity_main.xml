<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_dark"
    android:fitsSystemWindows="true">

    <View
        android:id="@+id/glowTop"
        android:layout_width="400dp"
        android:layout_height="400dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="-150dp"
        android:background="@drawable/glow_emerald"
        android:alpha="0.6" />

    <View
        android:id="@+id/glowBottom"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="-80dp"
        android:layout_marginBottom="-100dp"
        android:background="@drawable/glow_gold"
        android:alpha="0.4" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="48dp"
            android:paddingBottom="32dp">

            <!-- ═══ Header ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text=" muslim"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnSettings"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="⚙"
                    android:background="@drawable/circle_glass"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:layout_marginEnd="8dp" />

                <View
                    android:id="@+id/statusDot"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/dot_active"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="نشط"
                    android:textColor="@color/teal_400"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Location -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍"
                    android:textSize="12sp"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/tvLocationName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="جاري تحديد الموقع..."
                    android:textColor="@color/text_muted"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- ═══ HERO: Next Prayer ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_glass"
                android:padding="24dp"
                android:layout_marginBottom="12dp"
                android:elevation="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="الصلاة القادمة"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="bottom">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvNextPrayerNameArabic"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="الفجر"
                            android:textColor="@color/gold_400"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="2dp" />

                        <TextView
                            android:id="@+id/tvNextPrayerName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fajr"
                            android:textColor="@color/text_muted"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="end">

                        <TextView
                            android:id="@+id/tvNextPrayerTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="04:32"
                            android:textColor="@color/text_primary"
                            android:textSize="40sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-light" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/glass_border"
                    android:layout_marginVertical="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvCountdown"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="متبقي 2:15:00"
                        android:textColor="@color/teal_400"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvBlockingWindow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="حظر لمدة 20 دقيقة"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- ═══ TODAY'S PRAYERS - Inline Tracking ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_glass"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:elevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="صلوات اليوم"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvTodayScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 / 5"
                        android:textColor="@color/gold_400"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Prayer Row: each prayer is a horizontal bar with name, time, checkbox -->
                <LinearLayout
                    android:id="@+id/prayerTrackingContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>

            <!-- ═══ Quote ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_glass"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:elevation="4dp">

                <TextView
                    android:id="@+id/tvQuote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/gold_400"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:lineSpacingMultiplier="1.4"
                    android:textAlignment="viewStart"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvQuoteTranslation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/text_muted"
                    android:textSize="12sp"
                    android:textAlignment="viewStart"
                    android:lineSpacingMultiplier="1.3" />
            </LinearLayout>

            <!-- ═══ Quick Actions ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <Button
                    android:id="@+id/btnAthkar"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="أذكار"
                    android:textAllCaps="false"
                    android:background="@drawable/card_glass"
                    android:textColor="@color/teal_400"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/btnHadith"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="أحاديث"
                    android:textAllCaps="false"
                    android:background="@drawable/card_glass"
                    android:textColor="@color/gold_400"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/btnBlockedApps"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="حظر تطبيقات"
                    android:textAllCaps="false"
                    android:background="@drawable/card_glass"
                    android:textColor="@color/teal_400"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/btnDonate"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="تبرع 🤲"
                    android:textAllCaps="false"
                    android:background="@drawable/card_glass_gold"
                    android:textColor="@color/gold_400"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <!-- ═══ Settings Card (Compact) ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_glass"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:elevation="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="الإعدادات"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <!-- Blocking Toggle -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="منع التطبيقات"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="حظر أثناء الصلاة"
                            android:textColor="@color/text_muted"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <Switch
                        android:id="@+id/switchBlocking"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:thumbTint="@color/teal_500"
                        android:trackTint="@color/surface_card" />
                </LinearLayout>

                <!-- Notifications Toggle -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="إشعارات الصلاة"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="تنبيه قبل الصلاة"
                            android:textColor="@color/text_muted"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <Switch
                        android:id="@+id/switchNotifications"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:thumbTint="@color/teal_500"
                        android:trackTint="@color/surface_card" />
                </LinearLayout>

                <!-- Window Duration -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="مدة الحظر"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <SeekBar
                        android:id="@+id/seekBarWindow"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:max="60"
                        android:progress="20"
                        android:progressTint="@color/teal_500"
                        android:thumbTint="@color/teal_400"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/tvWindowMinutes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="20 دقيقة"
                        android:textColor="@color/teal_400"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Security Toggle -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="حماية التغييرات"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="بصمة أو PIN"
                            android:textColor="@color/text_muted"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <Switch
                        android:id="@+id/switchAuthRequired"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:thumbTint="@color/teal_500"
                        android:trackTint="@color/surface_card" />
                </LinearLayout>
            </LinearLayout>

            <!-- ═══ Accessibility + Test Mode (bottom) ═══ -->
            <Button
                android:id="@+id/btnEnableAccessibility"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="تفعيل خدمة الوصول"
                android:textAllCaps="false"
                android:background="@drawable/btn_emerald"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="مطلوب لمنع التطبيقات أثناء الصلاة"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <!-- Test Mode (collapsed) -->
            <LinearLayout
                android:id="@+id/testModeCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/card_glass"
                android:padding="12dp"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="وضع التجربة"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

                <Switch
                    android:id="@+id/switchTestMode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="@color/gold_500"
                    android:trackTint="@color/surface_card" />
            </LinearLayout>

            <!-- Test Mode Controls (hidden by default) -->
            <LinearLayout
                android:id="@+id/testModeControls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_glass"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <Spinner
                    android:id="@+id/spinnerTestPrayer"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="@drawable/spinner_glass"
                    android:layout_marginBottom="8dp" />

                <TimePicker
                    android:id="@+id/timePickerTest"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:timePickerMode="spinner" />

                <Button
                    android:id="@+id/btnApplyTestTime"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="تطبيق الوقت"
                    android:textAllCaps="false"
                    android:background="@drawable/btn_gold"
                    android:textColor="@color/surface_dark"
                    android:textSize="13sp"
                    android:layout_marginTop="8dp" />

                <Button
                    android:id="@+id/btnTestAdhan"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="🕌 اختبار الأذان"
                    android:textAllCaps="false"
                    android:background="@drawable/btn_gold"
                    android:textColor="@color/surface_dark"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</FrameLayout>
