<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/navy_950"
    android:fitsSystemWindows="true">

    <!-- Glow Effects -->
    <View
        android:layout_width="350dp"
        android:layout_height="350dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="-120dp"
        android:background="@drawable/glow_gold"
        android:alpha="0.4" />

    <View
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="-60dp"
        android:layout_marginBottom="-60dp"
        android:background="@drawable/glow_emerald"
        android:alpha="0.3" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="48dp"
            android:paddingBottom="32dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <Button
                    android:id="@+id/btnBackDonate"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="←"
                    android:background="@drawable/circle_glass"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="تبرع لنشر التطبيق"
                    android:textColor="@color/text_primary"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Islamic Calligraphy Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_glass_gold"
                android:padding="24dp"
                android:layout_marginBottom="20dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="بسم الله الرحمن الرحيم"
                    android:textColor="@color/gold_500"
                    android:textSize="22sp"
                    android:fontFamily="serif"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="مَنْ سَلَكَ طَرِيقًا يَلْتَمِسُ فِيهِ عِلْمًا سَهَّلَ اللهُ لَهُ طَرِيقًا إِلَى الجَنَّةِ"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:fontFamily="serif"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.6"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="رواه مسلم"
                    android:textColor="@color/text_muted"
                    android:textSize="13sp"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Purpose Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_glass"
                android:padding="20dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="لماذا نحتاج تبرعك؟"
                    android:textColor="@color/gold_500"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="هذا التطبيق مجاني بالكامل ولا يحتوي على أي إعلانات مزعجة. هدفه نشر العلم النافع وتسهيل أوقات الصلاة على المسلمين أينما كانوا."
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.5"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="تبرعك يُستخدم في:"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="✓ نشر التطبيق على Google Play através الإعلانات\n✓ الوصول لمزيد من المسلمين حول العالم\n✓ تحسين التطبيق وإضافة ميزات جديدة\n✓ جعله ثواباً لك في كل صلاة يصليها مسلم بمساعدة هذا التطبيق"
                    android:textColor="@color/teal_400"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.5" />
            </LinearLayout>

            <!-- Reward Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_glass"
                android:padding="20dp"
                android:layout_marginBottom="20dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="أجرك عند الله"
                    android:textColor="@color/gold_500"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="قال رسول الله ﷺ: &quot;مَنْ دَلَّ عَلَى خَيْرٍ فَلَهُ مِثْلُ أَجْرِ فَاعِلِهِ&quot;&#10;&#10;كل مسلم يصلي بصلاة هذا التطبيق فأنت شريك في أجره بإذن الله"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:fontFamily="serif"
                    android:lineSpacingMultiplier="1.5"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Vodafone Cash Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_glass_gold"
                android:padding="24dp"
                android:layout_marginBottom="20dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="التحويل عبر فودافون كاش"
                    android:textColor="@color/gold_500"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/glass_border_gold"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="رقم فودافون كاش"
                    android:textColor="@color/text_muted"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvCopyNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="01063448604"
                    android:textColor="@color/gold_500"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="16dp"
                    android:foreground="?android:selectableItemBackground" />

                <Button
                    android:id="@+id/btnCopyNumber"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="نسخ الرقم"
                    android:textAllCaps="false"
                    android:background="@drawable/btn_gold"
                    android:textColor="@color/navy_900"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- How to Donate Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_glass"
                android:padding="20dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="خطوات التبرع"
                    android:textColor="@color/gold_500"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1️⃣ افتح تطبيق فودافون كاش على هاتفك&#10;&#10;2️⃣ اختر &quot;تحويل&quot;&#10;&#10;3️⃣ ادخل الرقم: 01063448604&#10;&#10;4️⃣ اختر المبلغ الذي تريده&#10;&#10;5️⃣ أكمل التحويل&#10;&#10;6️⃣ كل ما تريد التبرع مرة أخرى، افتح هذا التطبيق واضغط &quot;تبرع&quot;"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.5" />
            </LinearLayout>

            <!-- Dua for Donor Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_glass"
                android:padding="20dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="دعاء للمتبرع 🤲"
                    android:textColor="@color/gold_500"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="اللهم تقبل من المتبرعين تبرعاتهم واجعلها في ميزان حسناتهم\n\nاللهم بارك في أموالهم وأزواجهم وأولادهم\n\nاللهم ارفع درجاتهم في الدنيا والآخرة\n\nاللهم لا تُضيع أجرهم واجعل هذا العمل خالصاً لوجهك الكريم"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:fontFamily="serif"
                    android:lineSpacingMultiplier="1.5"
                    android:gravity="center" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</FrameLayout>
