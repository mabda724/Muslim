<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_dark"
    android:fitsSystemWindows="true">

    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="-100dp"
        android:background="@drawable/glow_emerald"
        android:alpha="0.5" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="48dp"
            android:paddingBottom="32dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <Button
                    android:id="@+id/btnBackDashboard"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="←"
                    android:background="@drawable/circle_glass"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:layout_marginEnd="12dp" />

                <Button
                    android:id="@+id/btnReports"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="📊"
                    android:background="@drawable/circle_glass"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:layout_marginEnd="12dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="لوحة التتبع"
                        android:textColor="@color/text_primary"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">

                        <Switch
                            android:id="@+id/switchMuteMode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:thumbTint="@color/warning_amber"
                            android:trackTint="@color/surface_card" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="كتم التنبيهات"
                            android:textColor="@color/text_muted"
                            android:textSize="12sp"
                            android:layout_marginStart="6dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Encouragement Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_glass"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tvEncouragement"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/gold_400"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:lineSpacingMultiplier="1.4"
                    android:gravity="center"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvMotivational"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/teal_400"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:fontFamily="serif" />
            </LinearLayout>

            <!-- Today Progress -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_glass"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="تقدم اليوم"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tvTodayProgress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="اليوم - 60%"
                    android:textColor="@color/teal_400"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvPrayerCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3 / 5 صلوات"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:layout_marginBottom="12dp" />

                <ProgressBar
                    android:id="@+id/progressToday"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:max="100"
                    android:progress="60"
                    android:progressDrawable="@drawable/progress_emerald"
                    android:layout_marginBottom="16dp" />

                <!-- Mark Prayer Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <Button android:id="@+id/btnMarkFajr"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="فجر"
                        android:textAllCaps="false"
                        android:background="@drawable/btn_prayer"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:layout_marginEnd="4dp" />

                    <Button android:id="@+id/btnMarkDhuhr"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="ظهر"
                        android:textAllCaps="false"
                        android:background="@drawable/btn_prayer"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp" />

                    <Button android:id="@+id/btnMarkAsr"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="عصر"
                        android:textAllCaps="false"
                        android:background="@drawable/btn_prayer"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp" />

                    <Button android:id="@+id/btnMarkMaghrib"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="مغرب"
                        android:textAllCaps="false"
                        android:background="@drawable/btn_prayer"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp" />

                    <Button android:id="@+id/btnMarkIsha"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="عشاء"
                        android:textAllCaps="false"
                        android:background="@drawable/btn_prayer"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:layout_marginStart="4dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Stats Grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/card_glass"
                    android:padding="16dp"
                    android:gravity="center"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:id="@+id/tvStreak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5 يوم"
                        android:textColor="@color/gold_400"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="السلسلة الحالية"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/card_glass"
                    android:padding="16dp"
                    android:gravity="center"
                    android:layout_marginStart="6dp">

                    <TextView
                        android:id="@+id/tvLongestStreak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12 يوم"
                        android:textColor="@color/teal_400"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="أطول سلسلة"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Gamification Stats -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_glass"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="نقاط المستوى"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvTotalPoints"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="0 نقطة"
                        android:textColor="@color/gold_400"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:gravity="end" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvCurrentLevel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1 - مبتدئ"
                    android:textColor="@color/teal_400"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <ProgressBar
                    android:id="@+id/progressLevel"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:max="100"
                    android:progress="0"
                    android:progressDrawable="@drawable/progress_emerald" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/card_glass"
                    android:padding="16dp"
                    android:gravity="center"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:id="@+id/tvWeeklyAvg"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="85%"
                        android:textColor="@color/teal_300"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="متوسط الأسبوع"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/card_glass"
                    android:padding="16dp"
                    android:gravity="center"
                    android:layout_marginStart="6dp">

                    <TextView
                        android:id="@+id/tvTotalAllTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="150 صلاة"
                        android:textColor="@color/gold_300"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="إجمالي الصلوات"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Weekly Chart -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_glass"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="أداء هذا الأسبوع"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tvWeekChart"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/teal_400"
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:lineSpacingMultiplier="1.6" />
            </LinearLayout>

            <!-- Dhikr Rotation Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_glass_gold"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tvDhikrCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="أذكار"
                    android:textColor="@color/gold_400"
                    android:textSize="12sp"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvDhikrArabic"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:lineSpacingMultiplier="1.5"
                    android:textAlignment="viewStart"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvDhikrTranslation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/text_muted"
                    android:textSize="13sp"
                    android:textAlignment="viewStart" />
            </LinearLayout>

            <!-- Monthly Total -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_glass"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="إجمالي هذا الشهر"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvTotalMonth"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 صلاة"
                    android:textColor="@color/teal_400"
                    android:textSize="28sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</FrameLayout>
